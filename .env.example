# Cloudflare R2 credentials (create an API token in the R2 dashboard)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# The public base URL of your bucket. For dev: https://pub-<hash>.r2.dev
# For production, bind a custom domain to the bucket.
R2_PUBLIC_BASE_URL=

# Hard cap on total bucket storage before upload-time LRU eviction kicks in.
# Defaults to 50 GB if unset.
STORAGE_CAP_GB=50

# Shared secret Vercel Cron sends in the Authorization header when invoking
# /api/cleanup. Set this to any long random string.
CRON_SECRET=
